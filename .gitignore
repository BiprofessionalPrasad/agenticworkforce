# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# n8nlike backend data (persistent store)
data/
data/*.json
data/*.json.tmp

# Reports, build artifacts, temps, and tests (not for source control)
PROJECT_STATUS.md
QA_REPORT.md
TESTING_REPORT.md
build-check.txt
build.log
scripts/temp-*
tests/


